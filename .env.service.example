# Database Configuration
MONGODB_URI="mongodb://localhost:27017/ecommerce-db?replicaSet=rs0&directConnection=true"

# Message Broker Configuration
RABBITMQ_URL=amqp://localhost:5672

# Internal Service URLs
PAYMENT_SERVICE_URL=http://localhost:3004

# Security: JSON Web Token Secret (used for verifying internal requests)
JWT_SECRET=your-super-secret-jwt-key-must-be-changed-in-production

# Security: 32-byte Encryption Key for Field-Level Encryption (AES-256)
# Must be exactly 32 bytes (64 hex characters or 32 standard characters)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Observability
LOG_LEVEL=info
