    "@types/uuid": "^10.0.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
