{
  "name": "payment-service",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest --forceExit --detectOpenHandles --runInBand",
    "dev": "bun run --watch src/main/server.ts",
    "typecheck": "tsc --noEmit",
    "build:js": "bun run typecheck && bun build ./src/main/server.ts --outdir ./dist --target bun",
    "build:bin": "bun run typecheck && bun build ./src/main/server.ts --compile --outfile ./dist/payment_service",
    "start:js": "NODE_ENV=production bun run dist/server.js",
    "start:bin": "NODE_ENV=production ./dist/payment_service"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/bun": "^1.3.9",
    "amqplib": "^0.10.9",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^7.2.0",
